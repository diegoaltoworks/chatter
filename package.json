{
  "name": "@diegoaltoworks/chatter",
  "version": "0.13.0",
  "description": "Embeddable AI chatbot framework with RAG, authentication, and customizable widgets",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "chatter": "./dist/bin/create-apikey.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./mcp": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.mjs",
      "require": "./dist/mcp-server.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun run build:clean && bun run build:types && bun run build:esm && bun run build:cjs && bun run build:mcp && bun run build:bin && bun run build:client && bun run build:copy-client",
    "build:clean": "rm -rf dist",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:esm": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.mjs --external:hono --external:openai --external:@libsql/client --external:jose --platform=node --target=node24",
    "build:cjs": "esbuild src/index.ts --bundle --format=cjs --outfile=dist/index.js --external:hono --external:openai --external:@libsql/client --external:jose --platform=node --target=node24",
    "build:mcp": "esbuild src/mcp-server.ts --bundle --format=esm --outfile=dist/mcp-server.mjs --external:@modelcontextprotocol/sdk --external:openai --external:@libsql/client --external:zod --platform=node --target=node24 && esbuild src/mcp-server.ts --bundle --format=cjs --outfile=dist/mcp-server.js --external:@modelcontextprotocol/sdk --external:openai --external:@libsql/client --external:zod --platform=node --target=node24",
    "build:bin": "esbuild bin/create-apikey.ts --bundle --format=cjs --outfile=dist/bin/create-apikey.js --external:jose --platform=node --target=node18 --banner:js='#!/usr/bin/env node'",
    "build:client": "cd src/client && bun run build",
    "build:copy-client": "mkdir -p dist/static && cp src/client/dist/chatter.js src/client/dist/chatter.css dist/static/",
    "test": "bun test",
    "test:unit": "bun test src/**/*.test.ts",
    "test:integration": "bun test test/integration/**/*.test.ts",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "security:audit": "bun audit",
    "security:audit:fix": "bun update",
    "security:check": "bun audit --audit-level=moderate",
    "check": "bun run typecheck && bun run lint && bun run test && bun run security:check",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run security:check && bun run build",
    "prepare": "husky || true"
  },
  "keywords": [
    "chatbot",
    "ai",
    "rag",
    "embeddings",
    "openai",
    "hono",
    "chat-widget",
    "customer-support",
    "conversational-ai"
  ],
  "author": "Diego Alto <diego@diegoalto.works>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diegoaltoworks/chatter.git"
  },
  "bugs": {
    "url": "https://github.com/diegoaltoworks/chatter/issues"
  },
  "homepage": "https://github.com/diegoaltoworks/chatter#readme",
  "engines": {
    "node": ">=24.0.0"
  },
  "peerDependencies": {
    "@libsql/client": "^0.6.0 || ^0.7.0 || ^0.8.0 || ^0.9.0 || ^0.10.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hono": "^4.0.0 || ^5.0.0",
    "openai": "^4.0.0",
    "zod": "^3.25.0"
  },
  "dependencies": {
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/bun": "^1.1.12",
    "@types/node": "^22.9.1",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "typescript": "^6.0.2",
    "zod": "^3.25.76"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": ["biome check --write --no-errors-on-unmatched"],
    "*.ts": ["bash -c 'tsc --noEmit --skipLibCheck'"]
  }
}
